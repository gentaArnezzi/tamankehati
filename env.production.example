# 🌍 Taman Kehati - Production Environment Configuration
# Copy this file to .env and modify the values for your Ubuntu server
#
# ⚠️  CRITICAL FOR PRODUCTION:
# 1. NEVER commit .env file to version control
# 2. Generate a strong SECRET_KEY (minimum 32 characters)
# 3. Change all default passwords
# 4. Replace YOUR_SERVER_IP with actual server IP address
# 5. Set ENVIRONMENT=production and DEBUG=false
# 6. Configure CORS_ORIGINS with your server IP

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server IP Address - REPLACE WITH YOUR ACTUAL SERVER IP
# Example: 192.168.1.100 or 203.0.113.45
SERVER_IP=103.125.91.16

# Domain Name (Optional - if you have a domain)
# Leave empty if using IP-based access only
# Example: tamankehati.com
DOMAIN=

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database Configuration
# For Docker Compose, these will be used to build connection URLs
POSTGRES_DB=kehati_db
POSTGRES_USER=kehati_user
# ⚠️ CHANGE THIS to a strong password!
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Database URLs (automatically constructed from above, but can override)
# For Docker network, use service name 'postgres' as host
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis Cache URL
# For Docker network, use service name 'redis' as host
REDIS_URL=redis://redis:6379

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret Key - ⚠️ REQUIRED: Generate new one for production!
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use default value in production!
SECRET_KEY=GENERATE_NEW_SECRET_KEY_MINIMUM_32_CHARACTERS

# JWT Algorithm
ALGORITHM=HS256

# Token expiration time in minutes
# Standar industri: Access token 15 menit (OAuth2/JWT best practice)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expiration time in days
# Standar industri: Refresh token 7 hari (OAuth2/JWT best practice)
# Refresh token digunakan untuk mendapatkan access token baru tanpa perlu login ulang
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS CONFIGURATION (IP-Based)
# =============================================================================

# Allowed CORS origins - Use server IP address or domain
# Format (IP-based): http://YOUR_SERVER_IP:8080
# Format (Domain-based): https://yourdomain.com,https://www.yourdomain.com
# Can include multiple origins separated by commas
# If using domain, use HTTPS
CORS_ORIGINS=http://${SERVER_IP}:8080
# If using domain, uncomment and update:
# CORS_ORIGINS=https://${DOMAIN},https://www.${DOMAIN}

# Alternative CORS configuration (if using different variable name)
CORS_ALLOW_ORIGINS=${CORS_ORIGINS}

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Public base URL used by frontend build/runtime.
# The app adds `/api/...` itself when calling the backend through Nginx.
NEXT_PUBLIC_API_URL=http://${SERVER_IP}:8080
NEXT_PUBLIC_SITE_URL=http://${SERVER_IP}:8080

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================

# Environment type: MUST be "production" for production deployment
ENVIRONMENT=production

# Debug mode: MUST be "false" for production
DEBUG=false

# =============================================================================
# UPLOAD & FILE SETTINGS
# =============================================================================

# File upload settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp
UPLOAD_DIRECTORY=/app/uploads

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# =============================================================================
# FIREWALL CONFIGURATION (Optional but Recommended)
# =============================================================================

# Enable IP-based firewall for additional security
FIREWALL_ENABLED=true
FIREWALL_MODE=blacklist

# IP Whitelist: Comma-separated list of allowed IPs/CIDR ranges
# Example: "192.168.1.0/24,203.0.113.1,198.51.100.0/24"
IP_WHITELIST=

# IP Blacklist: Comma-separated list of blocked IPs/CIDR ranges
# Example: "1.2.3.4,5.6.7.8,10.0.0.0/8"
IP_BLACKLIST=

# Paths that bypass firewall (comma-separated)
# Health check endpoints should always be accessible
FIREWALL_BYPASS_PATHS=/health,/healthz,/api/health

# =============================================================================
# ADMIN USER CONFIGURATION
# =============================================================================

# Initial admin user (created automatically on first startup)
# ⚠️ CHANGE THESE from defaults!
ADMIN_EMAIL=admin@kehati.org
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# =============================================================================
# NGINX CONFIGURATION
# =============================================================================

# Nginx port (default: 80)
NGINX_PORT=8080

# Backend port (internal Docker network)
BACKEND_PORT=8000

# Frontend port (internal Docker network)
FRONTEND_PORT=3000

# =============================================================================
# DOCKER REGISTRY CONFIGURATION (For Pull-Only Deployment)
# =============================================================================

# Docker Registry URL (default: GitHub Container Registry)
DOCKER_REGISTRY=ghcr.io

# GitHub namespace / registry username
# Example: yourusername or your-org
DOCKER_USERNAME=yourusername

# Image tag version (default: latest)
# Use semantic versioning: v1.0.0, v1.0.1, etc.
IMAGE_TAG=latest

# =============================================================================
# OPTIONAL CONFIGURATIONS
# =============================================================================

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# AI Service Configuration (optional)
AI_PROVIDER=free
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# =============================================================================
# OLLAMA CONFIGURATION (Local LLM Server)
# =============================================================================

# Ollama Server URL
# ⚠️  PENTING: URL berbeda untuk local vs server Docker!
# 
# Untuk LOCAL DEVELOPMENT (Ollama di host):
#   OLLAMA_URL=http://localhost:11434
#
# Untuk SERVER DOCKER (Ollama di container):
#   OLLAMA_URL=http://ollama:11434  # Gunakan service name dari docker-compose
#   Atau: OLLAMA_URL=http://tamankehati-ollama-prod:11434  # Container name
#
# Default untuk server Docker (akan di-override oleh docker-compose)
OLLAMA_URL=http://ollama:11434

# Ollama Model Name
# Recommended models:
# - qwen2:1.5b (small, fast, good for Indonesian) - requires ~2GB RAM
# - qwen2.5:7b (medium, better quality) - requires ~7GB RAM
# - llama3.2:3b (alternative small model) - requires ~3GB RAM
# Download model first: ollama pull qwen2:1.5b
OLLAMA_MODEL=qwen2:1.5b

# Next.js Configuration
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_APP_NAME=Taman Kehati
NEXT_PUBLIC_APP_VERSION=2.1.0

# Map Configuration
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors
NEXT_PUBLIC_DEFAULT_LAT=-6.2088
NEXT_PUBLIC_DEFAULT_LNG=106.8456
NEXT_PUBLIC_DEFAULT_ZOOM=10

# Feature Flags
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_MAPS=true
NEXT_PUBLIC_ENABLE_UPLOADS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
#
# Before deploying, ensure you have:
#
# ✅ Generated new SECRET_KEY (32+ characters)
# ✅ Changed POSTGRES_PASSWORD to strong password
# ✅ Changed ADMIN_PASSWORD to strong password
# ✅ Updated SERVER_IP with actual server IP address
# ✅ Updated CORS_ORIGINS with server IP
# ✅ Updated NEXT_PUBLIC_API_URL with server IP
# ✅ Set ENVIRONMENT=production
# ✅ Set DEBUG=false
# ✅ FIREWALL_ENABLED=true (recommended)
# ✅ Reviewed all security settings
#
# =============================================================================
# QUICK START COMMANDS
# =============================================================================
#
# 1. Generate SECRET_KEY:
#    python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 2. Copy this file to .env:
#    cp env.production.example .env
#
# 3. Edit .env with your values:
#    nano .env
#
# 4. Build and start services:
#    docker-compose -f docker-compose.prod.yml build
#    docker-compose -f docker-compose.prod.yml up -d
#
# 5. Check service status:
#    docker-compose -f docker-compose.prod.yml ps
#
# 6. View logs:
#    docker-compose -f docker-compose.prod.yml logs -f
#
# =============================================================================
