# Standar industri: Access token 15 menit (OAuth2/JWT best practice)
ACCESS_TOKEN_EXPIRE_MINUTES="15"

# Refresh token expiration time in days
# Standar industri: Refresh token 7 hari (OAuth2/JWT best practice)
# Refresh token digunakan untuk mendapatkan access token baru tanpa perlu login ulang
REFRESH_TOKEN_EXPIRE_DAYS="7"

# =============================================================================
# ADMIN USER CONFIGURATION
# =============================================================================

# Admin user akan dibuat otomatis saat pertama kali backend start
# Jika admin sudah ada, script akan skip pembuatan admin baru

# Email untuk admin user default
# ⚠️  PENTING: Ganti email ini di production!
ADMIN_EMAIL="admin@kehati.org"

# Password untuk admin user default
# ⚠️  PENTING: Ganti password ini di production dengan password yang kuat!
# ⚠️  PENTING: Setelah login pertama kali, ganti password melalui dashboard!
ADMIN_PASSWORD="admin123"
