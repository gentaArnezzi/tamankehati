# 🌍 Taman Kehati Environment Configuration
# Copy this file to .env and modify the values as needed
#
# ⚠️  IMPORTANT FOR PRODUCTION DEPLOYMENT:
# 1. NEVER commit .env file to version control
# 2. Generate a strong SECRET_KEY (minimum 32 characters)
# 3. Change all default passwords
# 4. Set ENVIRONMENT=production and DEBUG=false
# 5. Configure CORS_ORIGINS with your actual domain
# 6. Update NEXT_PUBLIC_API_URL with your production API URL

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database URLs
# Format: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL="postgresql+asyncpg://kehati_user:kehati_password@localhost:5432/kehati_db"
DATABASE_URL_SYNC="postgresql://kehati_user:kehati_password@localhost:5432/kehati_db"

# Redis Cache URL
# Format: redis://host:port
REDIS_URL="redis://localhost:6379"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret Key - ⚠️ REQUIRED: CHANGE THIS IN PRODUCTION!
# Generate a secure random string (minimum 32 characters)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# DO NOT use this default value in production!
SECRET_KEY="your-secret-key-change-in-production-make-it-long-and-secure"

# JWT Algorithm
ALGORITHM="HS256"

# Token expiration time in minutes
<<<<<<< Updated upstream
