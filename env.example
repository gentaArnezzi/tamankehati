# =============================================================================
# FIREWALL CONFIGURATION
# =============================================================================

# Enable/Disable IP-based firewall
# Set to "true" in production for additional security
FIREWALL_ENABLED="false"

# Firewall mode: "whitelist" (only allow listed IPs) or "blacklist" (block listed IPs)
FIREWALL_MODE="blacklist"

# IP Whitelist: Comma-separated list of allowed IPs/CIDR ranges
# Example: "192.168.1.0/24,203.0.113.1,198.51.100.0/24"
IP_WHITELIST=""

# IP Blacklist: Comma-separated list of blocked IPs/CIDR ranges
# Example: "1.2.3.4,5.6.7.8,10.0.0.0/8"
IP_BLACKLIST=""

# Paths that bypass firewall (comma-separated)
# Health check endpoints should always be accessible
FIREWALL_BYPASS_PATHS="/health,/healthz,/api/health"

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed CORS origins (comma-separated)
# For development: include localhost and Docker internal URLs
# For production: specify exact domain names
CORS_ORIGINS="http://localhost:3000,http://frontend:3000"

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================

# Environment type: development, staging, production
ENVIRONMENT="development"

# Debug mode: true for development, false for production
DEBUG="true"

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# API URL for frontend (external access)
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Internal API URL for Docker network communication
API_BASE_URL="http://backend:8000"

# =============================================================================
# OPTIONAL CONFIGURATIONS
# =============================================================================

# Database connection pool settings
DB_POOL_SIZE="10"
DB_MAX_OVERFLOW="20"
DB_POOL_TIMEOUT="30"
DB_POOL_RECYCLE="3600"

# File upload settings
MAX_FILE_SIZE="10485760"  # 10MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp"
UPLOAD_DIRECTORY="./uploads"

# AI Service Configuration
AI_PROVIDER="free"  # Options: free, google, openai
AI_MODEL="gpt-3.5-turbo"
AI_MAX_TOKENS="1000"
AI_TEMPERATURE="0.7"

# =============================================================================
# OLLAMA CONFIGURATION (Local LLM Server)
# =============================================================================

# Ollama Server URL
# ⚠️  PENTING: URL berbeda untuk local vs server Docker!
# 
# Untuk LOCAL DEVELOPMENT (Ollama di host):
#   OLLAMA_URL="http://localhost:11434"
#
# Untuk SERVER DOCKER (Ollama di container):
#   OLLAMA_URL="http://ollama:11434"  # Gunakan service name dari docker-compose
#   Atau: OLLAMA_URL="http://tamankehati-ollama-prod:11434"  # Container name
#
# Default untuk local development
OLLAMA_URL="http://localhost:11434"

# Ollama Model Name
# Recommended models:
# - qwen2:1.5b (small, fast, good for Indonesian) - requires ~2GB RAM
# - qwen2.5:7b (medium, better quality) - requires ~7GB RAM
# - llama3.2:3b (alternative small model) - requires ~3GB RAM
# Download model first: ollama pull qwen2:1.5b
OLLAMA_MODEL="qwen2:1.5b"

# Logging Configuration
LOG_LEVEL="INFO"
LOG_FORMAT="json"
LOG_FILE="logs/app.log"

# Next.js Configuration
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED="1"
NEXT_PUBLIC_APP_NAME="Taman Kehati"
NEXT_PUBLIC_APP_VERSION="2.1.0"

# Map Configuration
NEXT_PUBLIC_MAP_TILE_URL="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
NEXT_PUBLIC_MAP_ATTRIBUTION="© OpenStreetMap contributors"
NEXT_PUBLIC_DEFAULT_LAT="-6.2088"
NEXT_PUBLIC_DEFAULT_LNG="106.8456"
NEXT_PUBLIC_DEFAULT_ZOOM="10"

# Feature Flags
NEXT_PUBLIC_ENABLE_AI="true"
NEXT_PUBLIC_ENABLE_MAPS="true"
NEXT_PUBLIC_ENABLE_UPLOADS="true"
NEXT_PUBLIC_ENABLE_NOTIFICATIONS="true"

# =============================================================================
# PRODUCTION DEPLOYMENT - REQUIRED CHANGES
# =============================================================================
#
# For production deployment, you MUST update the following:
#
# 1. SECRET_KEY - Generate new one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# 2. POSTGRES_PASSWORD - Change to strong password
# 3. CORS_ORIGINS - Set to your production domain(s), example:
#    CORS_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
# 4. NEXT_PUBLIC_API_URL - Set to your production API URL, example:
#    NEXT_PUBLIC_API_URL="https://api.yourdomain.com"
# 5. ENVIRONMENT="production"
# 6. DEBUG="false"
# 7. ADMIN_EMAIL and ADMIN_PASSWORD - Change from defaults
#
# Example production values (update these):
# SECRET_KEY="your-super-secure-production-secret-key-minimum-32-chars"
# CORS_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"
# ENVIRONMENT="production"
# DEBUG="false"
# POSTGRES_PASSWORD="your-strong-database-password"
# DATABASE_URL="postgresql+asyncpg://kehati_user:your-strong-password@postgres:5432/kehati_db"
# DATABASE_URL_SYNC="postgresql://kehati_user:your-strong-password@postgres:5432/kehati_db"
# NEXT_PUBLIC_API_URL="https://api.yourdomain.com"
# ADMIN_EMAIL="admin@yourdomain.com"
# ADMIN_PASSWORD="your-secure-admin-password"

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================

# SMTP settings for notifications
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USERNAME="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# SMTP_FROM_EMAIL="noreply@tamankehati.com"

# =============================================================================
# MONITORING (Optional)
# =============================================================================

# Sentry for error tracking
# SENTRY_DSN="https://your-sentry-dsn"

# Metrics collection
# ENABLE_METRICS="true"

# =============================================================================
# NOTES
# =============================================================================

# 1. Never commit this file with real credentials to version control
# 2. Use different values for development, staging, and production
# 3. Generate strong, unique secret keys for each environment
# 4. Update CORS_ORIGINS to match your actual domain in production
# 5. Use environment-specific database credentials
# 6. Enable SSL/TLS in production environments
# 7. Regular security audits and secret rotation recommended